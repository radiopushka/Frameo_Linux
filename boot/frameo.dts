	iio-hwmon {
		compatible = "iio-hwmon";
		io-channels = <0x33>;
	};

	opp-table-gpu {
		compatible = "operating-points-v2";
		phandle = <0x1f>;

		opp-144000000 {
			opp-hz = <0x00 0x8954400>;
		};

		opp-240000000 {
			opp-hz = <0x00 0xe4e1c00>;
		};

		opp-384000000 {
			opp-hz = <0x00 0x16e36000>;
		};
	};

	sound {
		compatible = "simple-audio-card";
		simple-audio-card,name = "sun8i-a33-audio";
		simple-audio-card,format = "i2s";
		simple-audio-card,frame-master = <0x34>;
		simple-audio-card,bitclock-master = <0x34>;
		simple-audio-card,mclk-fs = <0x80>;
		simple-audio-card,aux-devs = <0x35>;
		simple-audio-card,routing = "Left DAC", "DACL", "Right DAC", "DACR";
		status = "okay";
		phandle = <0x89>;

		simple-audio-card,cpu {
			sound-dai = <0x36>;
		};

		simple-audio-card,codec {
			sound-dai = <0x37 0x00>;
			phandle = <0x34>;
		};
	};

	thermal-zones {

		cpu-thermal {
			polling-delay-passive = <0xfa>;
			polling-delay = <0x3e8>;
			thermal-sensors = <0x33>;

			cooling-maps {

				map0 {
					trip = <0x38>;
					cooling-device = <0x39 0xffffffff 0xffffffff 0x3a 0xffffffff 0xffffffff 0x3b 0xffffffff 0xffffffff 0x3c 0xffffffff 0xffffffff>;
				};

				map1 {
					trip = <0x3d>;
					cooling-device = <0x39 0xffffffff 0xffffffff 0x3a 0xffffffff 0xffffffff 0x3b 0xffffffff 0xffffffff 0x3c 0xffffffff 0xffffffff>;
				};

				map2 {
					trip = <0x3e>;
					cooling-device = <0x3f 0x01 0xffffffff>;
				};

				map3 {
					trip = <0x40>;
					cooling-device = <0x3f 0x02 0xffffffff>;
				};
			};

			trips {

				cpu-alert0 {
					temperature = <0x124f8>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x38>;
				};

				gpu-alert0 {
					temperature = <0x14c08>;
					hysteresis = <0x7d0>;
					type = "passive";
					phandle = <0x3e>;
				};

				cpu-alert1 {
					temperature = <0x15f90>;
					hysteresis = <0x7d0>;
					type = "hot";
					phandle = <0x3d>;
				};

				gpu-alert1 {
					temperature = <0x17318>;
					hysteresis = <0x7d0>;
					type = "hot";
					phandle = <0x40>;
				};

				cpu-crit {
					temperature = <0x1adb0>;
					hysteresis = <0x7d0>;
					type = "critical";
					phandle = <0x8a>;
				};
			};
		};
	};

	ahci-5v {
		compatible = "regulator-fixed";
		regulator-name = "ahci-5v";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		regulator-boot-on;
		enable-active-high;
		gpio = <0x11 0x01 0x08 0x00>;
		status = "disabled";
		phandle = <0x8b>;
	};

	usb0-vbus {
		compatible = "regulator-fixed";
		regulator-name = "usb0-vbus";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		enable-active-high;
    regulator-always-on;
		status = "okay";
		phandle = <0x8c>;
	};

	usb1-vbus {
		compatible = "regulator-fixed";
		regulator-name = "usb1-vbus";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		regulator-boot-on;
		enable-active-high;
    regulator-always-on;
		status = "okay";
		phandle = <0x8d>;
	};

	usb2-vbus {
		compatible = "regulator-fixed";
		regulator-name = "usb2-vbus";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		regulator-boot-on;
		enable-active-high;
		gpio = <0x11 0x07 0x03 0x00>;
		status = "disabled";
		phandle = <0x8e>;
	};

	vcc3v0 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v0";
		regulator-min-microvolt = <0x2dc6c0>;
		regulator-max-microvolt = <0x2dc6c0>;
		phandle = <0x1b>;
	};

	vcc3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		phandle = <0x8f>;
	};

	vcc5v0 {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		phandle = <0x2f>;
	};

	aliases {
		serial0 = "/soc/serial@1f02800";
		ethernet0 = "/soc/mmc@1c10000/wifi@1";
		mmc0 = "/soc/mmc@1c0f000";
	};

	backlight {
		compatible = "pwm-backlight";
		pwms = <0x41 0x00 0xc350 0x01>;
		brightness-levels = <0x00 0x0a 0x14 0x1e 0x28 0x32 0x3c 0x46 0x50 0x5a 0x64>;
		default-brightness-level = <0x08>;
		enable-gpios = <0x11 0x07 0x06 0x00>;
		power-supply = <0x03>;
		phandle = <0x42>;
	};

	panel {
    compatible = "panel-simple";
		backlight = <0x42>;
		enable-gpios = <0x11 0x07 0x07 0x00>;
		power-supply = <0x03>;
		phandle = <0x90>;

		port {

			endpoint {
				remote-endpoint = <0x43>;
				phandle = <0x0e>;
			};
		};
	};

	pwrseq {
		compatible = "mmc-pwrseq-simple";
		post-power-on-delay-ms = <0xc8>;
    pinctrl-names = "default";
		pinctrl-0 = <0x44>;
    //reset-gpios = <0x11 0x0b 0x07 0x01>;
		phandle = <0x14>;
	};

	binman {
		multiple-images;
		phandle = <0x91>;

		u-boot-sunxi-with-spl {
			filename = "u-boot-sunxi-with-spl.bin";
			pad-byte = <0xff>;

			blob {
				min-size = <0x8000>;
				filename = "spl/sunxi-spl.bin";
			};

			u-boot-img {
			};
		};
	};

